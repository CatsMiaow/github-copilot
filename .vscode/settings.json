{
  "editor.aiStats.enabled": true,
  "workbench.browser.enableChatTools": true,

  "chat.agent.maxRequests": 125,
  "chat.useCustomAgentHooks": true,
  "chat.customAgentInSubagent.enabled": true,
  "chat.subagents.allowInvocationsFromSubagents": true,
  "chat.useCustomizationsInParentRepositories": true,

  "chat.useAgentSkills": true,
  "chat.useAgentsMdFile": true,
  "chat.useNestedAgentsMdFiles": true,

  //#region claude on/off
  "chat.useClaudeHooks": true,
  "chat.useClaudeMdFile": true,
  "chat.agentFilesLocations": {
    ".claude/agents": true,
    "~/.claude/agents": true
  },
  "chat.agentSkillsLocations": {
    ".claude/skills": true,
    "~/.claude/skills": true,
  },
  "chat.hookFilesLocations": {
    ".claude/settings.local.json": true,
    ".claude/settings.json": true,
    "~/.claude/settings.json": true,
  },
  "chat.instructionsFilesLocations": {
    ".claude/rules": true,
    "~/.claude/rules": true,
  },
  //#endregion

  "chat.exploreAgent.defaultModel": "Claude Haiku 4.5 (copilot)",
  "chat.planAgent.defaultModel": "Claude Opus 4.6 (copilot)",
  "inlineChat.defaultModel": "Claude Sonnet 4.6 (copilot)",
  "inlineChat.enableV2": true,

  "github.copilot.chat.languageContext.typescript.enabled": true,
  "github.copilot.chat.languageContext.fix.typescript.enabled": true,
  "github.copilot.chat.languageContext.inline.typescript.enabled": true,
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.nextEditSuggestions.extendedRange": true,

  "github.copilot.chat.agent.autoFix": true,
  "github.copilot.chat.agent.largeToolResultsToDisk.enabled": true,
  "github.copilot.chat.agent.omitFileAttachmentContents": true,
  "github.copilot.chat.agentDebugLog.enabled": true,
  "github.copilot.chat.agentDebugLog.fileLogging.enabled": true,

  "github.copilot.chat.copilotMemory.enabled": true,
  "github.copilot.chat.newWorkspace.useContext7": true,
  "github.copilot.chat.alternateGptPrompt.enabled": true,
  "github.copilot.chat.codesearch.enabled": true,
  "github.copilot.chat.searchSubagent.enabled": true,
  "github.copilot.chat.scopeSelection": true,

  "github.copilot.chat.responsesApiContextManagement.enabled": false,
  "github.copilot.chat.responsesApiReasoningSummary": "detailed",
  "github.copilot.chat.cli.mcp.enabled": true,
  "github.copilot.chat.cli.forkSessions.enabled": true,
  "github.copilot.chat.githubMcpServer.enabled": true,
  "github.copilot.chat.githubMcpServer.readonly": true,

  "github.copilot.chat.claudeAgent.enabled": true,
  "github.copilot.chat.claudeAgent.allowDangerouslySkipPermissions": true,

  //#region
  // This setting has an application scope and can only be set in the settings file from the Default profile.
  "chat.tips.enabled": true,
  "chat.plugins.marketplaces": ["anthropics/claude-code"]
  //#endregion
}
